      "fasm_path": "conv_compute_3tap.fasm",
      "kernel": "conv_compute_3tap",
      "notes": [
        "R3 = R0*csrX2 + R1*csrX3 + R2*csrX4 (3-tap weighted sum)."
      ]
    },
    {
      "fasm_path": "conv_gen_store_addr.fasm",
      "kernel": "conv_gen_store_addr",
      "notes": [
        "R4 = csrX5 + REGS0 (per-thread output address)."
      ]
    },
    {
      "fasm_path": "conv_store.fasm",
      "kernel": "conv_store",
      "notes": [
